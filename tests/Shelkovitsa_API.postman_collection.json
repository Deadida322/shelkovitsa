					"name": "Create Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Проверяем, что статус либо 201 (админ создан, база была пустая), либо 400 (админ уже существует)",
									"pm.test(\"Status code is 201 or 400\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([201, 400]);",
									"});",
									"",
									"if (pm.response.code === 201) {",
									"    pm.test(\"Admin created (database was empty)\", function () {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('mail');",
									"        pm.expect(jsonData).to.have.property('fio');",
									"        // Первый зарегистрированный пользователь становится админом",
									"    });",
									"} else {",
									"    pm.test(\"Admin already exists (expected behavior)\", function () {",
									"        pm.expect(pm.response.code).to.equal(400);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"mail\": \"admin@test.ru\",\n    \"fio\": \"Admin User\",\n    \"password\": \"Admin10091\",\n    \"rePassword\": \"Admin10091\"\n}"
						},
