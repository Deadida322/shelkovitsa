				{
					"name": "Admin Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has user data\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('mail');",
									"    pm.expect(jsonData).to.have.property('fio');",
									"});",
									"",
									"// Получаем токен из cookie",
									"var cookies = pm.cookies.toObject();",
									"if (cookies && cookies.access_token) {",
									"    pm.collectionVariables.set(\"adminToken\", cookies.access_token);",
									"} else {",
									"    // Если cookie не доступна, пробуем получить из заголовков Set-Cookie",
									"    var setCookieHeader = pm.response.headers.get('Set-Cookie');",
									"    if (!setCookieHeader) {",
									"        // Может быть массивом",
									"        var setCookieHeaders = pm.response.headers.toObject()['Set-Cookie'];",
									"        if (Array.isArray(setCookieHeaders)) {",
									"            setCookieHeader = setCookieHeaders.join('; ');",
									"        } else if (setCookieHeaders) {",
									"            setCookieHeader = setCookieHeaders;",
									"        }",
									"    }",
									"    if (setCookieHeader) {",
									"        var tokenMatch = setCookieHeader.match(/access_token=([^;]+)/);",
									"        if (tokenMatch && tokenMatch[1]) {",
									"            pm.collectionVariables.set(\"adminToken\", tokenMatch[1]);",
									"        }",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
